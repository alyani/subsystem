{
  "name": "alyani/subsystem",
  "type": "library",
  "keywords": [
    "subsystem"
  ],
  "description": "A feature-rich subsystem for Laravel projects.",
  "license": "MIT",
  "authors": [
    {
      "name": "Amir jahanpour",
      "email": "amri.jahanpour88@gmail.com"
    },
    {
      "name": "Neda Alyani",
      "email": "neda.alyani@gmail.com"
    }
  ],
  "require": {
    "php": ">=8.1",
    "firebase/php-jwt": "^7.0",
    "giggsey/libphonenumber-for-php": "^8.13",
    "laravel/sanctum": "*",
    "hekmatinasser/verta": "^8.4",
    "intervention/image": "^3.0",
    "laravel/ui": "^4.0",
    "mews/captcha": "^3.0",
    "paragonie/sodium_compat": "^1.17",
    "rybakit/msgpack": "^0.9.0",
    "spatie/laravel-html": "*",
    "yajra/laravel-datatables": "*"
  },
  "require-dev": {
    "orchestra/testbench": "^8.0"
  },
  "autoload": {
    "files": [
      "src/Helpers/Functions.php"
    ],
    "psr-4": {
      "Alyani\\Subsystem\\": "src",
      "Alyani\\Subsystem\\Database\\Seeders\\": "database/seeders"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Alyani\\Subsystem\\Tests\\": "tests"
    }
  },
  "config": {
    "sort-packages": true
  },
  "extra": {
    "laravel": {
      "providers": [
        "Alyani\\Subsystem\\Providers\\AuthServiceProvider",
        "Alyani\\Subsystem\\Providers\\SubsystemServiceProvider",
        "Alyani\\Subsystem\\Providers\\ValidationServiceProvider"
      ],
      "aliases": {
        "SmsService": "Alyani\\Subsystem\\Facade\\SmsService"
      }
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "test-coverage": "vendor/bin/phpunit --coverage-html coverage"
  }
}
